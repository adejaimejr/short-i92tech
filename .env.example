# ============================================
# Shlink - Configuração de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores reais.
# cp .env.example .env

#
.env

# --- Timezone ---
TZ=America/Sao_Paulo

# --- Domínio e HTTPS ---
# Domínio público onde o Shlink será acessado
SHLINK_DEFAULT_DOMAIN=short.i92tecnologia.com.br

# Habilitar HTTPS (true quando atrás de proxy com TLS)
SHLINK_IS_HTTPS_ENABLED=true

# --- Proxy Reverso ---
# Usar * para confiar em qualquer proxy (seguro quando não exposto diretamente)
# Pode ser um IP ou CIDR específico se preferir: ex. 10.0.0.0/8
SHLINK_TRUSTED_PROXIES=*

# --- Banco de Dados PostgreSQL (externo, já existente) ---
SHLINK_DB_DRIVER=postgres
SHLINK_DB_HOST=seu-host-postgres
SHLINK_DB_PORT=5432
SHLINK_DB_NAME=shlink
SHLINK_DB_USER=seu-usuario
SHLINK_DB_PASSWORD=sua-senha-segura

# --- API Key ---
# Chave da API gerada automaticamente no primeiro boot do Shlink.
# Use um valor seguro (ex: openssl rand -hex 32)
SHLINK_INITIAL_API_KEY=gere-uma-chave-segura-aqui

# --- GeoLite2 (opcional) ---
# Licença do MaxMind para geolocalização de cliques.
# Crie uma conta gratuita em: https://www.maxmind.com/en/geolite2/signup
# Deixe vazio para desabilitar geolocalização.
SHLINK_GEOLITE_LICENSE_KEY=
